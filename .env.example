# Copy to .env and adjust, or export these in your shell.
# This app does not load .env automatically unless you use a loader
# (e.g. `npx dotenv-cli -- npm start` or Render’s Environment dashboard).

# development | production — production makes the server listen on 0.0.0.0 when HOST is unset
NODE_ENV=production

# HTTP port (Render and most hosts set PORT for you; leave unset locally to use 3847)
PORT=3847

# Bind address: 127.0.0.1 for local-only; 0.0.0.0 for LAN or containers (Render sets NODE_ENV=production so HOST defaults to 0.0.0.0 if omitted)
HOST=0.0.0.0

# Max request body size for pasted markdown (Express text/json parser)
BODY_LIMIT=10mb
